{
  "name": "metis-desktop",
  "productName": "Metis",
  "version": "26.6.19",
  "description": "Metis desktop shell.",
  "author": "Metis",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1 --port 5174",
    "dev:electron": "wait-on http://127.0.0.1:5174 && cross-env METIS_DESKTOP_DEV_SERVER=http://127.0.0.1:5174 electron --no-sandbox --disable-gpu-sandbox --in-process-gpu --disable-gpu --disable-gpu-compositing --use-gl=swiftshader --enable-unsafe-swiftshader --disable-features=VizDisplayCompositor .",
    "dev": "node scripts/dev-launcher.mjs",
    "build-backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-backend.ps1",
    "build-svc": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-svc.ps1",
    "build": "tsc -b && vite build",
    "dist": "npm run test:fixed-regression && npm run build && electron-builder",
    "dist:win": "npm run test:fixed-regression && npm run build-backend && npm run build && electron-builder --win nsis",
    "perf:desktop": "node scripts/desktop-perf-runner.mjs",
    "smoke:desktop": "node scripts/desktop-smoke-runner.mjs",
    "test:contracts": "node --test scripts/desktop-contract-tests.mjs electron/security.test.cjs electron/data-root.test.cjs",
    "test:fixed-regression": "node scripts/fixed-regression-runner.mjs",
    "test:fixed-regression:list": "node scripts/fixed-regression-runner.mjs --list",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.14",
    "@assistant-ui/react-markdown": "^0.14.1",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^40.9.3",
    "electron-builder": "^26.15.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  }
}
